# lancache-ng (https://github.com/wiki-mod/lancache-ng)
# Watchdog service configuration for container monitoring and health checks (dev deployment).

# HTTP URL for the Docker socket proxy (haproxy with limited ACLs)
DOCKER_PROXY_URL=http://docker-socket-proxy:2375

# Whether to monitor and manage SSL-mode DNS service (dns-ssl container)
SSL_ENABLED=1

# Health check polling interval in seconds
CHECK_INTERVAL=30

# Number of consecutive health failures before restarting a container
RESTART_AFTER=3

# Disk usage warning threshold as percentage (yellow alert)
DISK_WARN_PCT=85

# Disk usage alarm threshold as percentage (red alert, critical)
DISK_ALARM_PCT=95

# Cache entries older than this many days are eligible for purge during daily cleanup
CACHE_VALID_DAYS=365

# Path to the shared cache directory (mounted from the host)
CACHE_DIR=/var/cache/lancache

# Docker container name for the unified proxy (handles both standard and SSL modes)
CONTAINER_PROXY=lancache-proxy

# Docker container name for the standard-mode DNS service
CONTAINER_DNS_STANDARD=lancache-dns-standard

# Docker container name for the SSL-mode DNS service
CONTAINER_DNS_SSL=lancache-dns-ssl

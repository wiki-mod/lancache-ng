# lancache-ng (https://github.com/wiki-mod/lancache-ng)
# PowerDNS configuration for SSL-mode proxy service (dev deployment).
PROXY_IP=127.0.0.1
LOG_QUERIES=1
PDNS_API_KEY=CHANGE_ME_PDNS_API_KEY
DDNS_ALLOW_FROM=172.28.0.6
ROOT_ZONE_MIRROR=0
NATS_CONSUMER=dns-ssl

# Known-good configuration snapshot retention (#415, #615). How many
# validated pdns.conf/recursor.conf configs to keep for automatic rollback
# if a newly generated config fails validation at startup. See
# docs/known-good-config-snapshots.md.
KEEP_KNOWN_GOOD_CONFIGS=3

# Dev: small cache for testing
CACHE_MAX_SIZE=10g
CACHE_MEM_MB=64
CACHE_SLICE_SIZE=8m
CACHE_VALID_HIT=365d
CACHE_VALID_ANY=1m
CACHE_INACTIVE=365d

# Real upstream DNS for nginx origin lookups. Do not set this to a LanCache DNS/proxy IP.
NGINX_UPSTREAM_RESOLVER=8.8.8.8 8.8.4.4

# Proxy security mode:
# - lazy (default): preserve LanCache-style behavior; proxy any host that reaches the cache.
#   This is a deliberate cache-first choice so new CDN hostnames keep working out of the box.
# - strict: only proxy hosts matching services/proxy/cdn-ssl-domains.txt.
PROXY_SECURITY_MODE=lazy

# Optional source-IP allowlist for clients that may use the proxy.
# Leave empty to allow all clients that can reach the bound LAN/Docker ports.
# Example: PROXY_ALLOWED_CLIENT_CIDRS=192.168.1.0/24 172.16.0.0/12
PROXY_ALLOWED_CLIENT_CIDRS=

# lancache-ng (https://github.com/wiki-mod/lancache-ng)
# DHCP relay/proxy service configuration (dev deployment).
DHCP_SUBNET_START=10.0.0.0
DHCP_DNS_PRIMARY=127.0.0.1
DHCP_DNS_SECONDARY=127.0.0.1
UPSTREAM_DHCP_IP=10.0.0.1

# DHCP-relay mode only (issue #844, DHCP_MODE=dnsmasq-relay): this relay's own
# address on the client-facing network. dnsmasq stamps it into the relayed
# packet's giaddr, which UPSTREAM_DHCP_IP uses to pick the client's pool.
# Unused in ProxyDHCP mode. Empty by default -- relay mode fails validation
# (and rolls back to a known-good config) until it is set.
DHCP_RELAY_LOCAL_ADDR=

# Issue #450: additional optional dnsmasq relay/proxy options. All empty by
# default -- ProxyDHCP mode works with only the four required values above.
# See docs/dhcp-modes.md for what each one actually delivers (PXE-scoped
# only, never to ordinary DHCP clients).
DHCP_PROXY_INTERFACE=
DHCP_PROXY_ROUTER=
DHCP_NTP_SERVERS=
DHCP_PROXY_DOMAIN=
DHCP_PROXY_BOOT_FILENAME=
DHCP_PROXY_BOOT_SERVER=
DHCP_PROXY_CUSTOM_OPTIONS=

# Issue #705: PXE boot-pointer opt-in, empty by default (no behavior change
# until both a server and at least one filename are set). See
# docs/dhcp-modes.md's "PXE boot-pointer" section.
DHCP_PROXY_PXE_BOOT_SERVER=
DHCP_PROXY_PXE_BOOT_FILENAME_BIOS=
DHCP_PROXY_PXE_BOOT_FILENAME_UEFI=

# Known-good configuration snapshot retention (#415). How many
# validated configs to keep for automatic rollback if a newly generated
# config fails validation at startup. See docs/known-good-config-snapshots.md.
KEEP_KNOWN_GOOD_CONFIGS=3

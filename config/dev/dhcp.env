# DHCP Server Configuration (Kea) - Development

DHCP_SUBNET=10.0.0.0/24
DHCP_RANGE_START=10.0.0.128
DHCP_RANGE_END=10.0.0.254
DHCP_GATEWAY=10.0.0.1
DHCP_DOMAIN=lan
DHCP_LEASE_TIME=3600
DHCP_NTP_SERVERS=

# DNS - will be set from UI env if available, defaults shown here
DHCP_DNS_PRIMARY=127.0.0.1
DHCP_DNS_SECONDARY=127.0.0.1

# Kea Control Agent authentication is shared with the Admin UI.
# Set KEA_CTRL_TOKEN in deploy/dev/.env (dev) or deploy/prod/.env (prod), not here,
# so Compose gives both services the same value.

# Bind address for Kea Control Agent REST API (port 8000)
# In dev: 0.0.0.0 is fine (isolated Docker bridge network)
# In prod with network_mode:host: restrict to Docker bridge gateway or firewall port 8000 on LAN interface
KEA_CTRL_HOST=0.0.0.0

# IP of the BIND9 DNS server that receives DDNS updates
# In dev: static IP of the dns-standard container in the lancache bridge network
DHCP_DNS_SERVER_IP=172.28.0.3

# DDNS TSIG key (auto-generated on first start if not set)
DDNS_TSIG_KEY=

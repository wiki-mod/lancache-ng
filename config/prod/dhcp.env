# DHCP Server Configuration (Kea) - Production

DHCP_SUBNET=10.0.0.0/24
DHCP_RANGE_START=10.0.0.128
DHCP_RANGE_END=10.0.0.254
DHCP_GATEWAY=10.0.0.1
DHCP_DOMAIN=lan
DHCP_LEASE_TIME=86400
DHCP_NTP_SERVERS=time.nist.gov

# DNS - set to the actual cache IPs
DHCP_DNS_PRIMARY=10.0.0.10
DHCP_DNS_SECONDARY=10.0.0.11

# Kea Control Agent authentication
KEA_CTRL_TOKEN=CHANGE_ME_KEA_CTRL_TOKEN

# Kea Control Agent REST API bind address (port 8000)
# SECURITY: network_mode:host exposes this on all interfaces including LAN.
# Firewall port 8000 on the LAN interface, or restrict to the Docker bridge gateway IP.
# Example: iptables -I INPUT -p tcp --dport 8000 ! -s 172.28.0.0/16 -j DROP
KEA_CTRL_HOST=0.0.0.0

# IP of the BIND9 DNS server that receives DDNS updates
# In prod: set from docker-compose environment (IP_STANDARD via network_mode:host)
DHCP_DNS_SERVER_IP=

# DDNS TSIG key (auto-generated on first start if not set)
DDNS_TSIG_KEY=

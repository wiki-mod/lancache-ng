# lancache-ng (https://github.com/wiki-mod/lancache-ng)
# PowerDNS configuration for SSL-mode proxy service (prod deployment).
# IP of the SSL-mode proxy (CA cert must be installed on clients).
# Set to the server's second LAN IP: ip addr add 192.168.1.11/24 dev eth0
PROXY_IP=192.168.234.11
# PROXY_IPV6=
LOG_QUERIES=0
PDNS_API_KEY=CHANGE_ME_PDNS_API_KEY
# DDNS_ALLOW_FROM is deliberately left empty here (issue #706): env_file
# values are literal, not ${VAR}-interpolated by Docker Compose, so a
# dynamic value like IP_STANDARD can't be filled in on this line. It is set
# instead in deploy/prod/docker-compose.yml's `environment:` block for this
# service (which DOES support compose variable interpolation, and takes
# precedence over this env_file for the same key), to
# ${IP_STANDARD},${IP_SSL} -- verified empirically on a real prod-like host
# (network_mode: host, two LAN IPs on one interface) that a DDNS update sent
# by the dhcp container always arrives with a source address equal to the
# host's *primary* LAN IP (IP_STANDARD in the documented setup flow, since
# IP_SSL is always the secondary alias added afterward via `ip addr add`),
# regardless of which of the two IPs the update was actually addressed to.
# IP_SSL is included too as a low-cost hedge against unusual host network
# topologies; TSIG (DDNS_TSIG_KEY) is the actual authentication control
# either way -- this allowlist is defense in depth, not the primary gate.
DDNS_ALLOW_FROM=
ROOT_ZONE_MIRROR=1
NATS_CONSUMER=dns-ssl

# Known-good configuration snapshot retention (#415, #615). How many
# validated pdns.conf/recursor.conf configs to keep for automatic rollback
# if a newly generated config fails validation at startup. See
# docs/known-good-config-snapshots.md.
KEEP_KNOWN_GOOD_CONFIGS=3

# lancache-ng (https://github.com/wiki-mod/lancache-ng)
# nginx HTTP/HTTPS proxy cache settings and security configuration (prod deployment).
# Prod: adjust CACHE_MAX_SIZE to your available disk space
CACHE_MAX_SIZE=50g
CACHE_MEM_MB=512
CACHE_SLICE_SIZE=8m
CACHE_VALID_HIT=365d
CACHE_VALID_ANY=1m
CACHE_INACTIVE=365d

# Real upstream DNS for nginx origin lookups. Do not set this to a LanCache DNS/proxy IP.
# Includes both IPv4 and IPv6 Google Public DNS addresses to match this project's
# dual-stack support (see CLAUDE.md); an IPv6-only/IPv6-preferring deployment
# still gets a working resolver even if IPv4 upstream reachability is limited.
NGINX_UPSTREAM_RESOLVER=8.8.8.8 8.8.4.4 2001:4860:4860::8888 2001:4860:4860::8844

# Proxy security mode:
# - lazy (default): preserve LanCache-style behavior; proxy any host that reaches the cache.
#   This is a deliberate cache-first choice so new CDN hostnames keep working out of the box.
# - strict: only proxy hosts derived from services/dns/cdn-domains.txt.
PROXY_SECURITY_MODE=lazy

# Optional source-IP allowlist for clients that may use the proxy.
# Leave empty to allow all clients that can reach the bound LAN/Docker ports.
# Example: PROXY_ALLOWED_CLIENT_CIDRS=192.168.1.0/24 172.16.0.0/12
PROXY_ALLOWED_CLIENT_CIDRS=

# Known-good configuration snapshot retention (#415). How many
# validated configs to keep for automatic rollback if a newly generated
# config fails validation at startup. See docs/known-good-config-snapshots.md.
KEEP_KNOWN_GOOD_CONFIGS=3

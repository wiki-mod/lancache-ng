# Prod: adjust CACHE_MAX_SIZE to your available disk space
CACHE_MAX_SIZE=500g
CACHE_MEM_MB=512
CACHE_SLICE_SIZE=8m
CACHE_VALID_HIT=365d
CACHE_VALID_ANY=1m
CACHE_INACTIVE=365d

# Real upstream DNS for nginx origin lookups. Do not set this to a LanCache DNS/proxy IP.
NGINX_UPSTREAM_RESOLVER=8.8.8.8 8.8.4.4

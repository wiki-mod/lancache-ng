DOCKER_PROXY_URL=http://docker-socket-proxy:2375
SSL_ENABLED=1
CHECK_INTERVAL=30
RESTART_AFTER=3
DISK_WARN_PCT=85
DISK_ALARM_PCT=95
CACHE_VALID_DAYS=365
CACHE_DIR_STANDARD=/cache/standard
CACHE_DIR_SSL=/cache/ssl
CONTAINER_PROXY_STANDARD=lancache-proxy-standard
CONTAINER_PROXY_SSL=lancache-proxy-ssl
CONTAINER_DNS_STANDARD=lancache-dns-standard
CONTAINER_DNS_SSL=lancache-dns-ssl

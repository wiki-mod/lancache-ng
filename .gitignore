# lancache-ng (https://github.com/wiki-mod/lancache-ng)
# Git ignore patterns for build artifacts, secrets, and generated files

# Cache data - never commit
data/
/cache/
/kea/
/nats/
/nats-conf/
/pdns-standard/
/pdns-ssl/
/pdns-filter-state/

# Generated certificates (keep only the CA template, not issued certs)
certs/*.crt
certs/*.key
certs/*.pem
!certs/.gitkeep

# Generated BIND9 keys (auto-created at container startup)
services/dns/keys/

# Generated Kea secrets (auto-created at container startup)
services/dhcp/keys/

# Environment files with secrets (root-level only)
/.env
/.env.dev
/.env.prod

# config/*.env files are committed (no secrets, just operational config)

# Claude Code project settings
.claude/

# OS
.DS_Store
Thumbs.db

# Rust build artifacts
services/ui/target/
services/dns/nats-subscriber/target/

# Editor
*.swp
*.swo
.idea/
.vscode/

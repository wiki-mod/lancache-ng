# IPs bound to each mode's services.
# The server needs two LAN IPs. Add the second with:
#   ip addr add 192.168.234.11/24 dev eth0
# To make it permanent, add it to /etc/network/interfaces or netplan.

IP_STANDARD=192.168.234.10
IP_SSL=192.168.234.11

# Shared TSIG key for Kea DDNS → PowerDNS updates. Generated by setup.sh.
# Keep this secret — it allows dynamic DNS updates to the LAN zone.
DDNS_TSIG_KEY=

# Internal NATS service accounts. setup.sh generates these automatically.
NATS_UI_USER=lancache-ui
NATS_UI_PASSWORD=
NATS_DNS_WRITER_USER=lancache-dns-writer
NATS_DNS_WRITER_PASSWORD=
NATS_DNS_READER_USER=lancache-dns-reader
NATS_DNS_READER_PASSWORD=

# Token used by setup.sh secondary to register new secondary DNS nodes.
# Generate with: openssl rand -hex 32
SECONDARY_REGISTRATION_TOKEN=

# Shared PowerDNS API key for DNS containers and Admin UI.
# Generated by setup.sh; or set manually with: openssl rand -hex 32
# Keep secret — this key controls the PowerDNS HTTP API.
PDNS_API_KEY=

# Kea Control Agent token shared by DHCP and Admin UI.
# Generate with: openssl rand -hex 32
KEA_CTRL_TOKEN=CHANGE_ME_KEA_CTRL_TOKEN

# Admin UI authentication.
# Set both values to enable Basic Auth.
# If both are empty, set ALLOW_INSECURE_UI=true only for an explicitly unauthenticated UI.
UI_AUTH_USER=
UI_AUTH_PASSWORD=
ALLOW_INSECURE_UI=false

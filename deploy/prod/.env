# IPs bound to each mode's services.
# The server needs two LAN IPs. Add the second with:
#   ip addr add 192.168.234.11/24 dev eth0
# To make it permanent, add it to /etc/network/interfaces or netplan.

IP_STANDARD=192.168.234.10
IP_SSL=192.168.234.11

# Shared TSIG key for Kea DDNS → BIND9 updates. Generated by setup.sh.
# Keep this secret — it allows dynamic DNS updates to the LAN zone.
DDNS_TSIG_KEY=

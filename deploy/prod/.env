# IPs bound to each mode's services.
# The server needs two LAN IPs. Add the second with:
#   ip addr add 192.168.234.11/24 dev eth0
# To make it permanent, add it to /etc/network/interfaces or netplan.

IP_STANDARD=192.168.234.10
IP_SSL=192.168.234.11

# Shared TSIG key for Kea DDNS → PowerDNS updates. Generated by setup.sh.
# Keep this secret — it allows dynamic DNS updates to the LAN zone.
DDNS_TSIG_KEY=

# Internal NATS service accounts. setup.sh generates these automatically.
NATS_UI_USER=lancache-ui
NATS_UI_PASSWORD=
NATS_DNS_WRITER_USER=lancache-dns-writer
NATS_DNS_WRITER_PASSWORD=
NATS_DNS_READER_USER=lancache-dns-reader
NATS_DNS_READER_PASSWORD=

# Token used by setup.sh secondary to register new secondary DNS nodes.
# Generate with: openssl rand -hex 32
SECONDARY_REGISTRATION_TOKEN=

# Shared PowerDNS API key for DNS containers and Admin UI.
# Generated by setup.sh; or set manually with: openssl rand -hex 32
# Keep secret — this key controls the PowerDNS HTTP API.
PDNS_API_KEY=

# Kea Control Agent token shared by DHCP and Admin UI.
# Generate with: openssl rand -hex 32
KEA_CTRL_TOKEN=CHANGE_ME_KEA_CTRL_TOKEN

# Admin UI authentication.
# Set both values to enable Basic Auth.
# If both are empty, set ALLOW_INSECURE_UI=true only for an explicitly unauthenticated UI.
UI_AUTH_USER=
UI_AUTH_PASSWORD=
ALLOW_INSECURE_UI=false

# First-party service image selector.
# latest is the latest stable release. Use edge only when you explicitly want
# the tested pre-stable channel, or a matching vX.Y.Z / vX.Y.Z-rc.N release tag.
LANCACHE_IMAGE_REGISTRY=ghcr.io
LANCACHE_IMAGE_PREFIX=wiki-mod/lancache-ng
LANCACHE_IMAGE_TAG=latest

# Production bind-mount state root.
# New installs use /opt/lancache-ng. Existing repository-based installs that
# already have state elsewhere should set this one root before the first manual
# compose run after upgrading, then leave the per-service overrides unset unless
# they intentionally split state across multiple disks.
LANCACHE_STATE_DIR=/opt/lancache-ng

# Optional per-service state overrides. Normally keep these commented so the
# compose file derives every state mount from LANCACHE_STATE_DIR.
# CACHE_DIR_STANDARD=/custom/cache
# CACHE_DIR_SSL=/custom/cache
# PDNS_STANDARD_DIR=/custom/pdns-standard
# PDNS_SSL_DIR=/custom/pdns-ssl
# PDNS_FILTER_STATE_DIR=/custom/pdns-filter-state
# KEA_DATA_DIR=/custom/kea
# NATS_DATA_DIR=/custom/nats
# NATS_CONF_DIR=/custom/nats-conf

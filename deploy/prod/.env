# Checked-in production template. For manual production installs, copy this to
# deploy/prod/.env.local, edit the untracked copy, and point manual compose
# commands at that file. setup.sh update/backup/restore/update-ip prefers
# deploy/prod/.env.local automatically when it exists.
#
# IPs bound to each mode's services.
# The server needs two LAN IPs. Add the second with:
#   ip addr add 192.168.234.11/24 dev eth0
# To make it permanent, add it to /etc/network/interfaces or netplan.

IP_STANDARD=192.168.234.10
IP_SSL=192.168.234.11

# Shared TSIG key for Kea DDNS → PowerDNS updates. Generated by setup.sh.
# Keep this secret — it allows dynamic DNS updates to the LAN zone.
DDNS_TSIG_KEY=

# Internal NATS service accounts. setup.sh generates these automatically.
# NATS_DNS_REPLICA_* is the primary's own co-located dns-ssl container --
# not a registered secondary. Registered secondaries each get their own
# per-instance NATS credential via auth callout instead (issue #583), issued
# at registration time and never stored in this file. NATS_CALLOUT_* is the
# Admin UI's own connection identity for answering those auth-callout
# requests.
NATS_UI_USER=lancache-ui
NATS_UI_PASSWORD=
NATS_DNS_WRITER_USER=lancache-dns-writer
NATS_DNS_WRITER_PASSWORD=
NATS_DNS_REPLICA_USER=lancache-dns-replica
NATS_DNS_REPLICA_PASSWORD=
NATS_CALLOUT_USER=lancache-nats-callout
NATS_CALLOUT_PASSWORD=
# System-account identity (issue #681): used only to look up and force-disconnect
# a removed/rotated secondary's live NATS connection. setup.sh generates a real
# password; REQUIRED, same as the other static NATS roles above.
NATS_SYS_USER=lancache-nats-sys
NATS_SYS_PASSWORD=

# Token used by setup.sh secondary to register new secondary DNS nodes.
# REQUIRED even if you never register a secondary DNS node: the ui
# container's boot-time check refuses to start on an empty or placeholder
# value (an empty token used to allow unauthenticated secondary
# registration -- see issue #659). Only the one registration route is
# actually disabled if you skip secondary DNS; the token itself is not
# optional, matching setup.sh's own unconditional generation of this value.
# Generate with: openssl rand -hex 32
SECONDARY_REGISTRATION_TOKEN=CHANGE_ME_SECONDARY_REGISTRATION_TOKEN

# Shared PowerDNS API key for DNS containers and Admin UI.
# Generated by setup.sh; or set manually with: openssl rand -hex 32
# Keep secret — this key controls the PowerDNS HTTP API.
PDNS_API_KEY=

# Kea Control Agent token shared by DHCP and Admin UI.
# Generate with: openssl rand -hex 32
KEA_CTRL_TOKEN=CHANGE_ME_KEA_CTRL_TOKEN

# Admin UI authentication.
# Set both values to enable Basic Auth.
# If both are empty, set ALLOW_INSECURE_UI=true only for an explicitly unauthenticated UI.
UI_AUTH_USER=
UI_AUTH_PASSWORD=
ALLOW_INSECURE_UI=false

# First-party service image selector.
# latest is the latest stable release. Use nightly only when you explicitly want
# the tested pre-stable channel (built daily from master; formerly called edge),
# or a matching vX.Y.Z / vX.Y.Z-rc.N release tag.
# ghcr.io hosts the published LanCache-NG runtime images. The mirror.gcr.io
# references elsewhere in the repo are only Dockerfile base-image mirrors used
# while building images, not the registry that production compose should pull.
LANCACHE_IMAGE_REGISTRY=ghcr.io
LANCACHE_IMAGE_PREFIX=wiki-mod/lancache-ng
LANCACHE_IMAGE_TAG=latest

# Production bind-mount state root.
# New installs use /opt/lancache-ng. Existing repository-based installs that
# already have state elsewhere should set this one root before the first manual
# compose run after upgrading, then leave the per-service overrides unset unless
# they intentionally split state across multiple disks.
LANCACHE_STATE_DIR=/opt/lancache-ng

# Optional per-service state overrides. Normally keep these commented so the
# compose file derives every state mount from LANCACHE_STATE_DIR.
# CACHE_DIR is the one cache-path override as of v0.2.0 (issue #445). The old
# split CACHE_DIR_STANDARD/CACHE_DIR_SSL keys are EOL: no compose file reads
# them anymore, so setting either one by hand in this file is a silent no-op.
# setup.sh update still reads them exactly once, to migrate a pre-v0.2.0
# install's existing path into CACHE_DIR, then deletes both keys.
# CACHE_DIR=/custom/cache
# setup.sh update only writes the keys below when it must preserve a real
# legacy/custom path that no longer matches the shared state root.
# PDNS_STANDARD_DIR=/custom/pdns-standard
# PDNS_SSL_DIR=/custom/pdns-ssl
# PDNS_FILTER_STATE_DIR=/custom/pdns-filter-state
# KEA_DATA_DIR=/custom/kea
# NATS_DATA_DIR=/custom/nats
# NATS_CONF_DIR=/custom/nats-conf
# SYSLOG_NG_LOG_DIR=/custom/syslog-ng

# Central logging (#453; opt-in via --profile logging). Safe defaults; only
# uncomment to change the rotation threshold or compression level.
# SYSLOG_MAX_FILE_MB=100
# SYSLOG_COMPRESSION_LEVEL=19
# SYSLOG_NG_ROTATE_INTERVAL_SECONDS=300

# Syslog storage-budget retention engine (#633; watchdog.sh's
# maybe_prune_syslog()). This is a DOUBLE opt-in: SYSLOG_ENABLED must be
# explicitly set to "true" below. The `watchdog` container that runs this
# engine always runs (it has no compose `profiles:` gate, unlike `syslog`/
# `syslog-ng`), so starting `--profile logging` alone does NOT enable
# pruning -- it only starts the log producers that create the tree pruning
# would act on. This is deliberate so turning on central logging never
# starts deleting files an operator didn't separately ask to have pruned.
# When enabled: files older than SYSLOG_RETENTION_DAYS are deleted first; if
# the tree is still over SYSLOG_MAX_GB afterward, the oldest remaining files
# are deleted next (regardless of age) until back under budget -- size
# budget takes priority over retention days.
# SYSLOG_ENABLED=false
# SYSLOG_MAX_GB=10
# SYSLOG_RETENTION_DAYS=30

# Dev: both modes share 127.0.0.1 but use different DNS ports (see compose).
# NOTE: Port 53 conflicts with Windows DNS client — see DNS service comment.
IP_STANDARD=127.0.0.1
IP_SSL=127.0.0.1

# Shared TSIG key for Kea DDNS → BIND9 updates (HMAC-SHA256, base64).
# Dev: fixed key for reproducible dev environment.
# Prod: generated by setup.sh — do not commit the prod .env.
DDNS_TSIG_KEY=aGVsbG93b3JsZGxhbmNhY2hlZGV2a2V5Zm9yZGV2b25seQ==

# Kea Control Agent token shared by DHCP and Admin UI.
# Generate with: openssl rand -hex 32
KEA_CTRL_TOKEN=lancache-dev-kea-control-token-change-me

# Internal NATS service accounts for local development. NATS_DNS_REPLICA_*
# is the primary's own co-located dns-ssl container -- not the same thing as
# a registered secondary, which gets its own per-instance credential via
# NATS auth callout instead (issue #583; see nats_auth_callout.rs).
# NATS_CALLOUT_* is the Admin UI's own connection identity for answering
# those auth-callout requests.
NATS_UI_USER=lancache-ui
NATS_UI_PASSWORD=lancache-nats-ui-dev-secret
NATS_DNS_WRITER_USER=lancache-dns-writer
NATS_DNS_WRITER_PASSWORD=lancache-nats-writer-dev-secret
NATS_DNS_REPLICA_USER=lancache-dns-replica
NATS_DNS_REPLICA_PASSWORD=lancache-nats-replica-dev-secret
NATS_CALLOUT_USER=lancache-nats-callout
NATS_CALLOUT_PASSWORD=lancache-nats-callout-dev-secret

# Admin UI authentication.
# Set both values to enable Basic Auth.
# If both are empty, set ALLOW_INSECURE_UI=true only for an explicitly unauthenticated UI.
UI_AUTH_USER=
UI_AUTH_PASSWORD=
ALLOW_INSECURE_UI=false

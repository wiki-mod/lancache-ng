# ── LAN-IPs ───────────────────────────────────────────────────────────────────
# Standard-Modus (kein CA-Zertifikat nötig): HTTP gecacht, HTTPS durchgeleitet
IP_STANDARD=192.168.234.10

# SSL-Modus (CA-Zertifikat auf Clients installieren): HTTP + HTTPS gecacht
IP_SSL=192.168.234.11

# Zweite IP hinzufügen falls noch nicht vorhanden:
#   ip addr add 192.168.234.11/24 dev eth0

# ── Cache ─────────────────────────────────────────────────────────────────────
# Unified cache directory for both standard and SSL modes
CACHE_DIR=/opt/lancache-ng/cache

# nginx enforces CACHE_MAX_SIZE inside the proxy; the Admin UI displays the
# same capacity via CACHE_MAX_GB. Keep both values aligned when editing by hand.
CACHE_MAX_SIZE=50g
CACHE_MAX_GB=50
# Memory and slice settings tune nginx's shared cache metadata and range-cache
# chunking. They are intentionally independent from the on-disk CACHE_DIR.
CACHE_MEM_MB=512
CACHE_SLICE_SIZE=8m
CACHE_VALID_HIT=365d
CACHE_VALID_ANY=1m
CACHE_INACTIVE=365d

# Real upstream DNS for nginx origin lookups. Do not set this to a LanCache DNS/proxy IP.
NGINX_UPSTREAM_RESOLVER=8.8.8.8 8.8.4.4

# First-party service image selector.
# latest is the latest stable release. Use edge only when you explicitly want
# the tested pre-stable channel, or a matching vX.Y.Z / vX.Y.Z-rc.N release tag.
# setup.sh writes these keys so quickstart can run without a local Git checkout.
LANCACHE_IMAGE_REGISTRY=ghcr.io
LANCACHE_IMAGE_PREFIX=wiki-mod/lancache-ng
LANCACHE_IMAGE_TAG=latest

# ── PowerDNS API ──────────────────────────────────────────────────────────────
# API key for PowerDNS Authoritative + Recursor. Generated by setup.sh.
PDNS_API_KEY=CHANGE_ME_PDNS_API_KEY

# ── NATS (DNS-record sync bus) ─────────────────────────────────────────────────
# Local NATS users used by UI, DNS writer, and DNS reader services.
# setup.sh generates real passwords. Manual deploys must replace these placeholders.
NATS_UI_USER=lancache-ui
NATS_UI_PASSWORD=CHANGE_ME_NATS_UI_PASSWORD
NATS_DNS_WRITER_USER=lancache-dns-writer
NATS_DNS_WRITER_PASSWORD=CHANGE_ME_NATS_DNS_WRITER_PASSWORD
NATS_DNS_READER_USER=lancache-dns-reader
NATS_DNS_READER_PASSWORD=CHANGE_ME_NATS_DNS_READER_PASSWORD
# Token für setup-secondary.sh — jeder, der diesen kennt, kann einen Secondary registrieren.
# Manual deploys: replace with a different real secret generated by: openssl rand -hex 32
SECONDARY_REGISTRATION_TOKEN=YOUR_SECONDARY_REGISTRATION_TOKEN_HERE

# Admin UI authentication.
# Set both values to enable Basic Auth.
# If both are empty, set ALLOW_INSECURE_UI=true only for an explicitly unauthenticated UI.
UI_AUTH_USER=
UI_AUTH_PASSWORD=
ALLOW_INSECURE_UI=false

# Kea DHCP control/API secret. Generated by setup.sh for real installs.
KEA_CTRL_TOKEN=CHANGE_ME_KEA_CTRL_TOKEN

# Shared TSIG key for DHCP DDNS updates. Generated by setup.sh for real installs.
# Leave empty unless Kea DHCP/DDNS is enabled; placeholder values make DNS fail closed.
DDNS_TSIG_KEY=

# ── DHCP mode ────────────────────────────────────────────────────────────────
# disabled: keep the existing router DHCP server.
# kea: run LanCache-NG Kea as the full DHCP server.
# dnsmasq-proxy: experimental proxy-DHCP helper; requires the values below.
DHCP_MODE=disabled
DHCP_SUBNET_START=
DHCP_DNS_PRIMARY=
DHCP_DNS_SECONDARY=
UPSTREAM_DHCP_IP=
